<Window x:Class="WorkRecordAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WorkRecordAssistant.ViewModels"
        xmlns:ctrl="clr-namespace:WorkRecordAssistant.Controls"
        Title="工作记录助手"
        Icon="pack://application:,,,/Resources/app-icon.png"
        Width="380" Height="520"
        MinWidth="380" MinHeight="400"
        MaxWidth="480" MaxHeight="900"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Topmost="True"
        UseLayoutRounding="True"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei UI">

    <Window.Resources>
        <conv:StringNotEmptyToVisibilityConverter xmlns:conv="clr-namespace:WorkRecordAssistant.Converters"
                                                  x:Key="StringNotEmptyToVis" />
        <conv:BoolToVisibilityConverter xmlns:conv="clr-namespace:WorkRecordAssistant.Converters"
                                      x:Key="BoolVis" />
    </Window.Resources>

    <Border Background="{DynamicResource BackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="10"
            PreviewMouseLeftButtonDown="Window_PreviewMouseLeftButtonDown">

        <Grid>
            <Grid x:Name="MainContent" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题栏 / 拖动区（整块顶部空白区域均可拖动） -->
            <Grid Grid.Row="0" x:Name="TitleBarGrid" MinHeight="36" Margin="0,0,0,8"
                  Background="Transparent"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="工作记录"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False" />
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource IconButton}" Content="⚙" ToolTip="设置" Click="OpenSettings_Click" />
                    <Button Style="{StaticResource IconButton}" Content="—" ToolTip="隐藏到托盘" Click="Minimize_Click" />
                    <Button Style="{StaticResource IconButton}" Content="✕" ToolTip="隐藏到托盘" Click="Close_Click" />
                </StackPanel>
            </Grid>

            <!-- 快捷按钮 -->
            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,8">
                <ItemsControl ItemsSource="{Binding QuickButtons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:QuickButtonViewModel}">
                            <Button Style="{StaticResource QuickLinkButton}"
                                    Content="{Binding Name}"
                                    Command="{Binding DataContext.OpenQuickButtonCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- 日期切换 -->
            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Padding="8" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource IconButton}" Content="◀"
                            Command="{Binding GoPreviousDayCommand}" ToolTip="上一天" />
                    <Button Grid.Column="1"
                            Style="{StaticResource SecondaryButton}"
                            Content="{Binding DateDisplay}"
                            HorizontalAlignment="Stretch"
                            Margin="4,0"
                            Click="DateButton_Click"
                            Background="Transparent" />
                    <Button Grid.Column="2" Style="{StaticResource IconButton}" Content="▶"
                            Command="{Binding GoNextDayCommand}" ToolTip="下一天" />
                    <Button Grid.Column="3" Style="{StaticResource SecondaryButton}" Content="今天"
                            Command="{Binding GoTodayCommand}" Margin="4,0,0,0" />
                </Grid>
            </Border>

            <!-- 工作记录列表 -->
            <Border Grid.Row="3" Style="{StaticResource CardBorder}" Padding="4" Margin="0,0,0,8">
                <ctrl:RecordListView x:Name="RecordList"
                                     TaskItems="{Binding TaskItems}"
                                     StarredTaskCount="{Binding StarredTaskCount}"
                                     DeleteRequested="RecordList_DeleteRequested"
                                     CompleteRequested="RecordList_CompleteRequested"
                                     OpenArchiveRequested="RecordList_OpenArchiveRequested"
                                     RecordEditingChanged="RecordList_RecordEditingChanged" />
            </Border>

            <!-- 任务输入框（点击「添加任务」后显示） -->
            <Grid Grid.Row="4"
                  Margin="0,0,0,8"
                  Visibility="{Binding IsInputPanelVisible, Converter={StaticResource BoolVis}}"
                  IsVisibleChanged="InputPanel_IsVisibleChanged">
                <TextBox x:Name="InputBox"
                         Style="{StaticResource RoundedTextBox}"
                         Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MinHeight="36"
                         MaxHeight="120"
                         GotFocus="InputBox_GotFocus"
                         LostFocus="InputBox_LostFocus"
                         PreviewKeyDown="InputBox_PreviewKeyDown" />
                <TextBlock Text="输入任务，Enter 添加 · Shift+Enter 换行"
                           IsHitTestVisible="False"
                           VerticalAlignment="Top"
                           Margin="12,10,12,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="13">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding Text, ElementName=InputBox}" Value="" />
                                        <Condition Binding="{Binding IsFocused, ElementName=InputBox}" Value="False" />
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible" />
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>

            <!-- 操作按钮 -->
            <Grid Grid.Row="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource CopyButton}"
                        Content="一键复制"
                        ToolTip="复制当天已完成任务"
                        Margin="0,0,4,0"
                        Command="{Binding CopyTodayCommand}" />
                <Button Grid.Column="1"
                        Style="{StaticResource PrimaryButton}"
                        Content="添加任务"
                        ToolTip="添加任务"
                        Margin="4,0,0,0"
                        Command="{Binding ShowTaskInputCommand}" />
            </Grid>

            <!-- 状态栏 -->
            <TextBlock Grid.Row="6"
                       Text="{Binding StatusMessage}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="11"
                       Margin="0,6,0,0"
                       HorizontalAlignment="Center"
                       Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToVis}}" />
            </Grid>

            <!-- 收起时显示在屏幕边缘的可点击细条 -->
            <Border x:Name="CollapsedStripOverlay"
                    Visibility="Collapsed"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource PrimaryBrush}"
                    Opacity="0.85"
                    CornerRadius="6"
                    Cursor="Hand"
                    ToolTip="点击或悬停展开"
                    MouseLeftButtonDown="CollapsedStripOverlay_MouseLeftButtonDown"
                    MouseEnter="CollapsedStripOverlay_MouseEnter">
                <TextBlock Text="⋮"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False" />
            </Border>
        </Grid>
    </Border>
</Window>
