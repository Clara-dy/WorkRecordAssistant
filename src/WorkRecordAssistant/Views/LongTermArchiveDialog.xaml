<Window x:Class="WorkRecordAssistant.Views.LongTermArchiveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:WorkRecordAssistant.Converters"
        Title="长期任务归档箱"
        Width="360" Height="420"
        MinWidth="300" MinHeight="320"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei UI">

    <Window.Resources>
        <conv:CountToVisibilityConverter x:Key="CountVis" />
        <conv:CountToVisibilityConverter x:Key="EmptyVis" />
        <conv:StringNotEmptyToVisibilityConverter x:Key="StringNotEmptyToVis" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="已结束的长期任务"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimaryBrush}"
                   Margin="0,0,0,8" />

        <Border Grid.Row="1"
                Style="{StaticResource CardBorder}"
                Padding="4">
            <Grid>
                <TextBlock Text="暂无归档任务"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="{Binding Items.Count, Converter={StaticResource EmptyVis}, ConverterParameter=Inverse}" />

                <ListBox ItemsSource="{Binding Items}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Visibility="{Binding Items.Count, Converter={StaticResource CountVis}}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource LongTermTaskBackgroundBrush}"
                                    CornerRadius="6"
                                    Padding="8,6"
                                    Margin="0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DisplayText}"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="13"
                                               VerticalAlignment="Center" />
                                    <Button Grid.Column="1"
                                            Style="{StaticResource SecondaryButton}"
                                            Content="复制"
                                            Padding="10,4"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center"
                                            Command="{Binding DataContext.CopyItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusMessage}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="11"
                   Margin="0,8,0,0"
                   HorizontalAlignment="Center"
                   Visibility="{Binding StatusMessage, Converter={StaticResource StringNotEmptyToVis}}" />

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Style="{StaticResource CopyButton}"
                    Content="复制全部"
                    Width="96"
                    Margin="0,0,8,0"
                    Command="{Binding CopyAllCommand}" />
            <Button Style="{StaticResource SecondaryButton}"
                    Content="关闭"
                    Width="80"
                    Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
