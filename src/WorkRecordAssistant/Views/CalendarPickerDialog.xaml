<Window x:Class="WorkRecordAssistant.Views.CalendarPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择日期"
        Width="320" Height="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei UI">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Calendar x:Name="CalendarControl"
                  Background="{DynamicResource SurfaceBrush}"
                  BorderBrush="{DynamicResource BorderBrush}" />
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="取消" Width="80" Margin="0,0,8,0" Click="Cancel_Click" />
            <Button Style="{StaticResource PrimaryButton}" Content="确定" Width="80" Click="Ok_Click" />
        </StackPanel>
    </Grid>
</Window>
