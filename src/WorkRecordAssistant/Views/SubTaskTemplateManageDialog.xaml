<Window x:Class="WorkRecordAssistant.Views.SubTaskTemplateManageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="管理快速子任务"
        Width="360"
        Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei UI">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="右键主任务时可快速添加下列子任务"
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10" />

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Background="{DynamicResource SurfaceBrush}"
                Padding="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="TemplateList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Content}"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           Margin="4,0,8,0" />
                                <Button Grid.Column="1"
                                        Content="删除"
                                        Style="{StaticResource SecondaryButton}"
                                        Padding="10,4"
                                        FontSize="12"
                                        MinHeight="28"
                                        Click="DeleteButton_Click"
                                        Tag="{Binding}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="NewTemplateBox"
                     Style="{StaticResource RoundedTextBox}"
                     FontSize="13"
                     MinHeight="36"
                     Padding="10,8"
                     VerticalContentAlignment="Center"
                     KeyDown="NewTemplateBox_KeyDown" />
            <Button Grid.Column="1"
                    Content="添加"
                    Style="{StaticResource PrimaryButton}"
                    Margin="8,0,0,0"
                    MinWidth="72"
                    MinHeight="36"
                    Padding="12,6"
                    Click="AddButton_Click" />
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消"
                    Style="{StaticResource SecondaryButton}"
                    MinWidth="80"
                    MinHeight="36"
                    Padding="16,8"
                    Margin="0,0,8,0"
                    Click="Cancel_Click" />
            <Button Content="保存"
                    Style="{StaticResource PrimaryButton}"
                    MinWidth="80"
                    MinHeight="36"
                    Padding="16,8"
                    Click="Save_Click" />
        </StackPanel>
    </Grid>
</Window>
