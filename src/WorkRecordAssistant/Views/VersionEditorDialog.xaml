<Window x:Class="WorkRecordAssistant.Views.VersionEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置版本号"
        Width="360" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei UI"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style x:Key="CalcKeyButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="3" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="版本号（纯数字）"
                   FontSize="13"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   Margin="0,0,0,6" />
        <TextBox x:Name="VersionNumberBox"
                 Grid.Row="1"
                 IsReadOnly="True"
                 FontSize="24"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource VersionTextBrush}"
                 Padding="12,10"
                 MinHeight="44"
                 Margin="0,0,0,14"
                 Style="{StaticResource RoundedTextBox}"
                 GotFocus="VersionNumberBox_GotFocus" />

        <StackPanel Grid.Row="2" Margin="0,0,0,14">
            <TextBlock Text="版本信息"
                       FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,0,6" />
            <TextBox x:Name="VersionInfoBox"
                     IsReadOnly="True"
                     FontSize="18"
                     Foreground="{DynamicResource VersionTextBrush}"
                     Padding="12,10"
                     MinHeight="40"
                     Style="{StaticResource RoundedTextBox}"
                     GotFocus="VersionInfoBox_GotFocus" />
        </StackPanel>

        <UniformGrid Grid.Row="3"
                     Columns="3"
                     Rows="4"
                     Margin="0,0,0,14">
            <Button Content="7" Style="{StaticResource CalcKeyButton}" Click="Digit_Click" />
            <Button Content="8" Style="{StaticResource CalcKeyButton}" Click="Digit_Click" />
            <Button Content="9" Style="{StaticResource CalcKeyButton}" Click="Digit_Click" />
            <Button Content="4" Style="{StaticResource CalcKeyButton}" Click="Digit_Click" />
            <Button Content="5" Style="{StaticResource CalcKeyButton}" Click="Digit_Click" />
            <Button Content="6" Style="{StaticResource CalcKeyButton}" Click="Digit_Click" />
            <Button Content="1" Style="{StaticResource CalcKeyButton}" Click="Digit_Click" />
            <Button Content="2" Style="{StaticResource CalcKeyButton}" Click="Digit_Click" />
            <Button Content="3" Style="{StaticResource CalcKeyButton}" Click="Digit_Click" />
            <Button Content="." Style="{StaticResource CalcKeyButton}" Click="Dot_Click" />
            <Button Content="0" Style="{StaticResource CalcKeyButton}" Click="Digit_Click" />
            <Button Content="⌫" Style="{StaticResource CalcKeyButton}" FontSize="18" Click="Backspace_Click" />
        </UniformGrid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Style="{StaticResource SecondaryButton}"
                    Content="清空"
                    Height="40"
                    FontSize="14"
                    Margin="0,0,8,0"
                    Click="Clear_Click" />
            <Button Grid.Column="1"
                    Style="{StaticResource SecondaryButton}"
                    Content="取消"
                    Width="80"
                    Height="40"
                    FontSize="14"
                    Margin="0,0,8,0"
                    Click="Cancel_Click" />
            <Button Grid.Column="2"
                    Style="{StaticResource PrimaryButton}"
                    Content="确定"
                    Width="80"
                    Height="40"
                    FontSize="14"
                    IsDefault="True"
                    Click="Ok_Click" />
        </Grid>
    </Grid>
</Window>
