<UserControl x:Class="WorkRecordAssistant.Controls.RecordListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:WorkRecordAssistant.Controls"
             xmlns:conv="clr-namespace:WorkRecordAssistant.Converters">

    <UserControl.Resources>
        <conv:CountToVisibilityConverter x:Key="CountVis" />
        <conv:CountToVisibilityConverter x:Key="EmptyVis" />
        <Style x:Key="RecordListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 任务列表标题 -->
        <Grid Grid.Row="0" Margin="4,0,4,6">
            <TextBlock Text="任务列表"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource IconButton}"
                        Content="⇅"
                        ToolTip="切换已完成任务排序"
                        Command="{Binding ToggleSortOrderCommand, RelativeSource={RelativeSource AncestorType=Window}}" />
                <Button Style="{StaticResource IconButton}"
                        Content="📦"
                        ToolTip="任务归档箱"
                        Click="OpenArchive_Click" />
            </StackPanel>
        </Grid>

        <!-- 合并任务列表 -->
        <Grid Grid.Row="1">
            <!-- 空状态占位 -->
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="16"
                        Visibility="{Binding TaskItems.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource EmptyVis}, ConverterParameter=Inverse}">
                <Viewbox Width="96" Height="96" Margin="0,0,0,12" Opacity="0.55">
                    <Canvas Width="120" Height="120">
                        <Rectangle Canvas.Left="20" Canvas.Top="10" Width="72" Height="96" RadiusX="8" RadiusY="8"
                                   Fill="{DynamicResource AccentSubtleBrush}" Stroke="{DynamicResource PrimaryBrush}" StrokeThickness="3" />
                        <Rectangle Canvas.Left="34" Canvas.Top="32" Width="44" Height="4" RadiusX="2" RadiusY="2"
                                   Fill="{DynamicResource PrimaryBrush}" Opacity="0.5" />
                        <Rectangle Canvas.Left="34" Canvas.Top="46" Width="36" Height="4" RadiusX="2" RadiusY="2"
                                   Fill="{DynamicResource PrimaryBrush}" Opacity="0.35" />
                        <Rectangle Canvas.Left="34" Canvas.Top="60" Width="40" Height="4" RadiusX="2" RadiusY="2"
                                   Fill="{DynamicResource PrimaryBrush}" Opacity="0.35" />
                        <Ellipse Canvas.Left="78" Canvas.Top="78" Width="28" Height="28"
                                 Fill="{DynamicResource PrimaryBrush}" Opacity="0.85" />
                        <Path Data="M88,88 L94,94 L104,82" Stroke="White" StrokeThickness="3"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" />
                    </Canvas>
                </Viewbox>
                <TextBlock Text="暂无任务"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="右键可标注星级任务"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Opacity="0.8"
                           Margin="0,4,0,0"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <ListBox x:Name="TaskListBox"
                     ItemsSource="{Binding TaskItems, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     Visibility="{Binding TaskItems.Count, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource CountVis}}">
                <ListBox.ItemContainerStyle>
                    <StaticResource ResourceKey="RecordListBoxItemStyle" />
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ctrl:RecordListItem Loaded="RecordListItem_Loaded" Unloaded="RecordListItem_Unloaded" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- 拖拽插入指示线 -->
        <Border x:Name="InsertIndicator"
                Grid.RowSpan="2"
                Height="2"
                Background="{DynamicResource PrimaryBrush}"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Margin="8,0"
                Visibility="Collapsed"
                IsHitTestVisible="False" />
    </Grid>
</UserControl>
