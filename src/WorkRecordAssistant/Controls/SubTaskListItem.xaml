<UserControl x:Class="WorkRecordAssistant.Controls.SubTaskListItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:WorkRecordAssistant.Converters"
             ClipToBounds="True"
             Margin="12,1,0,1">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <Border x:Name="DeleteBackground"
                Background="{DynamicResource DangerBrush}"
                HorizontalAlignment="Right"
                Width="64"
                CornerRadius="4"
                Opacity="0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🗑" FontSize="14" HorizontalAlignment="Center" />
                <TextBlock Text="删除" Foreground="White" FontSize="10" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <Grid x:Name="ContentPanel" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="SlideTransform" />
            </Grid.RenderTransform>

            <Border x:Name="SubTaskHeaderArea"
                    CornerRadius="4"
                    Padding="2,4,8,4"
                    Background="Transparent"
                    Cursor="Hand"
                    MouseRightButtonUp="SubTaskHeaderArea_MouseRightButtonUp">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="复制"
                                  Click="CopyMenuItem_Click" />
                        <MenuItem Header="设置版本号"
                                  Click="SetVersionMenuItem_Click" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Width="18"
                            Height="18"
                            Margin="0,0,6,0"
                            VerticalAlignment="Top"
                            Cursor="Hand"
                            ToolTip="单击切换完成"
                            MouseLeftButtonDown="CompleteToggle_MouseLeftButtonDown">
                        <Grid Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <!-- 子任务未完成：空心圆 -->
                            <Ellipse Width="11"
                                     Height="11"
                                     StrokeThickness="1.5"
                                     Stroke="{DynamicResource TextSecondaryBrush}"
                                     Fill="Transparent"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Opacity="0.85">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <!-- 子任务已完成：实心圆 + 勾 -->
                            <Grid Visibility="{Binding IsCompleted, Converter={StaticResource BoolVis}}">
                                <Ellipse Width="11"
                                         Height="11"
                                         Fill="{DynamicResource TaskCompleteBrush}"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center" />
                                <Path Data="M3.2,7 L5.6,9.4 L10.2,4.2"
                                      Stroke="White"
                                      StrokeThickness="1.5"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Width="14"
                                      Height="14"
                                      Stretch="None"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="1">
                        <StackPanel x:Name="DisplayPanel">
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,2"
                                        Visibility="{Binding ShowTimeVersionHint, Converter={StaticResource BoolVis}}">
                                <TextBlock Text="{Binding TimePart}"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,6,0"
                                           Visibility="{Binding ShowTimePart, Converter={StaticResource BoolVis}}" />
                                <TextBlock Text="{Binding VersionNumberPart}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource VersionTextBrush}"
                                           Margin="0,0,6,0"
                                           Visibility="{Binding ShowVersionNumberPart, Converter={StaticResource BoolVis}}" />
                                <TextBlock Text="·"
                                           FontSize="12"
                                           Foreground="{DynamicResource VersionTextBrush}"
                                           Margin="0,0,6,0"
                                           Visibility="{Binding ShowVersionInfoPart, Converter={StaticResource BoolVis}}" />
                                <TextBlock Text="{Binding VersionInfoPart}"
                                           FontSize="12"
                                           Foreground="{DynamicResource VersionTextBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding ShowVersionInfoPart, Converter={StaticResource BoolVis}}" />
                            </StackPanel>
                            <TextBlock Text="{Binding DisplayText}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Setter Property="Foreground" Value="{DynamicResource TaskIncompleteBrush}" />
                                    <Setter Property="TextDecorations" Value="{x:Null}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                            <Setter Property="Foreground" Value="{DynamicResource TaskCompleteBrush}" />
                                            <Setter Property="TextDecorations" Value="Underline" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        </StackPanel>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBox x:Name="EditTextBox"
                                     Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="28"
                                     FontSize="14"
                                     Style="{StaticResource RoundedTextBox}"
                                     PreviewKeyDown="EditTextBox_PreviewKeyDown" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
