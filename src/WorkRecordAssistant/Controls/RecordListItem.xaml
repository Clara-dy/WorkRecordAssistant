<UserControl x:Class="WorkRecordAssistant.Controls.RecordListItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             ClipToBounds="True"
             Margin="0,2">

    <Grid x:Name="RootGrid">
        <!-- 左滑删除背景 -->
        <Border x:Name="DeleteBackground"
                Background="{DynamicResource DangerBrush}"
                HorizontalAlignment="Right"
                Width="72"
                CornerRadius="6"
                Opacity="0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🗑" FontSize="16" HorizontalAlignment="Center" />
                <TextBlock Text="删除" Foreground="White" FontSize="11" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <Grid x:Name="ContentPanel" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="SlideTransform" />
            </Grid.RenderTransform>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 拖动手柄：按住即可排序 -->
            <Border x:Name="DragHandle"
                    Grid.Column="0"
                    Width="22"
                    Cursor="SizeAll"
                    ToolTip="按住拖动排序"
                    Background="Transparent"
                    MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
                <TextBlock Text="⋮⋮"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.45" />
            </Border>

            <!-- 内容区 -->
            <Border Grid.Column="1"
                    CornerRadius="6"
                    Padding="4,6,8,6"
                    x:Name="ContentArea">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLongTermTask}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource LongTermTaskBackgroundBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <TextBlock x:Name="DisplayTextBlock"
                               Text="{Binding DisplayText}"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="13"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBox x:Name="EditTextBox"
                                 Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="32"
                                 Style="{StaticResource RoundedTextBox}"
                                 KeyDown="EditTextBox_KeyDown" />
                        <Button Content="完成"
                                Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Right"
                                Margin="0,6,0,0"
                                Padding="16,6"
                                Click="DoneButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Button Grid.Column="2"
                    Content="结束"
                    Padding="8,4"
                    FontSize="11"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    Click="CompleteButton_Click">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource LongTermButton}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsLongTermTask}" Value="True" />
                                    <Condition Binding="{Binding IsEditing}" Value="False" />
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible" />
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</UserControl>
