<UserControl x:Class="WorkRecordAssistant.Controls.RecordListItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="clr-namespace:WorkRecordAssistant.Controls"
             xmlns:conv="clr-namespace:WorkRecordAssistant.Converters"
             x:Name="Root"
             ClipToBounds="True"
             Margin="0,2">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <Border x:Name="DeleteBackground"
                Background="{DynamicResource DangerBrush}"
                HorizontalAlignment="Right"
                Width="72"
                CornerRadius="6"
                Opacity="0">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🗑" FontSize="16" HorizontalAlignment="Center" />
                <TextBlock Text="删除" Foreground="White" FontSize="11" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <Grid x:Name="ContentPanel" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="SlideTransform" />
            </Grid.RenderTransform>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="DragHandle"
                    Grid.Column="0"
                    Width="22"
                    Cursor="SizeAll"
                    ToolTip="按住拖动排序"
                    Background="Transparent"
                    MouseLeftButtonDown="DragHandle_MouseLeftButtonDown">
                <TextBlock Text="⋮⋮"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Opacity="0.45" />
            </Border>

            <Border Grid.Column="1"
                    CornerRadius="6"
                    Padding="4,6,8,6"
                    x:Name="ContentArea">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStarred}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource StarredTaskBackgroundBrush}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <!-- 主任务区：手势仅作用于此 -->
                    <Border x:Name="TaskHeaderArea"
                            Background="Transparent"
                            Cursor="Hand"
                            Padding="0,0,0,2"
                            MouseRightButtonUp="TaskHeaderArea_MouseRightButtonUp">
                        <Border.ContextMenu>
                            <ContextMenu Opened="TaskContextMenu_Opened">
                                <MenuItem x:Name="StarMenuItem"
                                          Header="标注为星级任务"
                                          Click="StarMenuItem_Click" />
                                <MenuItem x:Name="UnstarMenuItem"
                                          Header="取消星级"
                                          Click="UnstarMenuItem_Click" />
                                <Separator />
                                <MenuItem Header="设置版本号"
                                          Click="SetVersionMenuItem_Click" />
                                <MenuItem Header="复制">
                                    <MenuItem Header="含子任务"
                                              Click="CopyWithSubTasks_Click" />
                                    <MenuItem Header="仅任务"
                                              Click="CopyTaskOnly_Click" />
                                </MenuItem>
                                <MenuItem x:Name="QuickSubTaskMenu"
                                          Header="快速子任务" />
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="CompleteToggle"
                                    Grid.Column="0"
                                    Width="22"
                                    Height="22"
                                    Margin="0,0,6,0"
                                    VerticalAlignment="Top"
                                    Cursor="Hand"
                                    ToolTip="单击切换完成"
                                    MouseLeftButtonDown="CompleteToggle_MouseLeftButtonDown">
                                <Grid Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <!-- 主任务未完成：圆角方框 -->
                                    <Border Width="14"
                                            Height="14"
                                            CornerRadius="3"
                                            BorderThickness="1.6"
                                            BorderBrush="{DynamicResource TaskIncompleteBrush}"
                                            Background="Transparent"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <!-- 主任务已完成：实心圆角方框 + 勾 -->
                                    <Grid Visibility="{Binding IsCompleted, Converter={StaticResource BoolVis}}">
                                        <Border Width="14"
                                                Height="14"
                                                CornerRadius="3"
                                                Background="{DynamicResource TaskCompleteBrush}"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                        <Path Data="M3.5,8 L6.5,11 L12,4.5"
                                              Stroke="White"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Width="16"
                                              Height="16"
                                              Stretch="None"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                    </Grid>
                                </Grid>
                            </Border>

                            <Grid Grid.Column="1">
                                <StackPanel x:Name="DisplayPanel">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="{Binding StartDateHint}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,0,0,2"
                                               Visibility="{Binding ShowStartDateHint, Converter={StaticResource BoolVis}}" />
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,2"
                                                Visibility="{Binding ShowTimeVersionHint, Converter={StaticResource BoolVis}}">
                                        <TextBlock Text="{Binding TimePart}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="0,0,6,0"
                                                   Visibility="{Binding ShowTimePart, Converter={StaticResource BoolVis}}" />
                                        <TextBlock Text="{Binding VersionNumberPart}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource VersionTextBrush}"
                                                   Margin="0,0,6,0"
                                                   Visibility="{Binding ShowVersionNumberPart, Converter={StaticResource BoolVis}}" />
                                        <TextBlock Text="·"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource VersionTextBrush}"
                                                   Margin="0,0,6,0"
                                                   Visibility="{Binding ShowVersionInfoPart, Converter={StaticResource BoolVis}}" />
                                        <TextBlock Text="{Binding VersionInfoPart}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource VersionTextBrush}"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding ShowVersionInfoPart, Converter={StaticResource BoolVis}}" />
                                    </StackPanel>
                                    <TextBlock x:Name="DisplayTextBlock"
                                               Text="{Binding DisplayText}"
                                               TextWrapping="Wrap"
                                               FontSize="15"
                                               FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource TaskIncompleteBrush}" />
                                                <Setter Property="TextDecorations" Value="{x:Null}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="Foreground" Value="{DynamicResource TaskCompleteBrush}" />
                                                        <Setter Property="TextDecorations" Value="Underline" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel>
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBox x:Name="EditTextBox"
                                             Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             MinHeight="32"
                                             FontSize="15"
                                             FontWeight="SemiBold"
                                             Style="{StaticResource RoundedTextBox}"
                                             KeyDown="EditTextBox_KeyDown" />
                                    <Button Content="保存"
                                            Style="{StaticResource PrimaryButton}"
                                            HorizontalAlignment="Right"
                                            Margin="0,6,0,0"
                                            Padding="16,6"
                                            Click="DoneButton_Click" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Grid.Column="2"
                                       Text="★"
                                       FontSize="13"
                                       Foreground="{DynamicResource StarIconBrush}"
                                       VerticalAlignment="Top"
                                       Margin="6,2,0,0"
                                       Visibility="{Binding IsStarred, Converter={StaticResource BoolVis}}" />
                        </Grid>
                    </Border>

                    <!-- 子任务：独立交互，不触发主任务手势 -->
                    <StackPanel Margin="0,2,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <ItemsControl ItemsSource="{Binding SubTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ctrl:SubTaskListItem Loaded="SubTaskListItem_Loaded"
                                                          Unloaded="SubTaskListItem_Unloaded" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Visibility="{Binding IsAddingSubTask, Converter={StaticResource BoolVis}}">
                            <TextBox x:Name="NewSubTaskBox"
                                     Text="{Binding NewSubTaskText, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     MinHeight="28"
                                     FontSize="14"
                                     Margin="12,2,0,2"
                                     Style="{StaticResource RoundedTextBox}"
                                     PreviewKeyDown="NewSubTaskBox_PreviewKeyDown"
                                     Loaded="NewSubTaskBox_Loaded" />
                        </StackPanel>

                        <Button Content="＋ 子任务"
                                HorizontalAlignment="Left"
                                Margin="8,2,0,0"
                                Padding="4,2"
                                FontSize="11"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="{DynamicResource TextSecondaryBrush}"
                                Cursor="Hand"
                                Click="AddSubTask_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsAddingSubTask}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
